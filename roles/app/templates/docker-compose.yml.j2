# 1 process = 1 container. Secrets injectés via .env (jamais en dur).
services:
  mysql:
    image: mysql:8.0
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD}
      MYSQL_DATABASE: ${MYSQL_DATABASE}
      MYSQL_USER: ${MYSQL_USER}
      MYSQL_PASSWORD: ${MYSQL_PASSWORD}
    volumes:
      - {{ project_dir }}/mysql:/var/lib/mysql
    networks:
      - wp_network
    # Pas de ports exposés : la base n'est jamais joignable depuis Internet.

  wordpress:
    image: wordpress:php8.1-fpm
    restart: always
    depends_on:
      - mysql
    environment:
      WORDPRESS_DB_HOST: mysql
      WORDPRESS_DB_NAME: ${MYSQL_DATABASE}
      WORDPRESS_DB_USER: ${MYSQL_USER}
      WORDPRESS_DB_PASSWORD: ${MYSQL_PASSWORD}
    volumes:
      - {{ project_dir }}/wp:/var/www/html
    networks:
      - wp_network

  phpmyadmin:
    image: phpmyadmin:latest
    restart: always
    depends_on:
      - mysql
    environment:
      PMA_HOST: mysql
      PMA_PORT: "3306"
      # Sert phpMyAdmin correctement derrière nginx sur le sous-chemin /phpmyadmin/.
      PMA_ABSOLUTE_URI: https://{{ ansible_host }}{% if https_port | int != 443 %}:{{ https_port }}{% endif %}/phpmyadmin/
    networks:
      - wp_network
    # Accessible uniquement via le reverse-proxy nginx (pas de port hôte).

  nginx:
    image: nginx:alpine
    restart: always
    depends_on:
      - wordpress
      - phpmyadmin
    ports:
      - "{{ http_port }}:80"
      - "{{ https_port }}:443"
    volumes:
      - {{ project_dir }}/nginx/nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - {{ project_dir }}/wp:/var/www/html
      - {{ project_dir }}/ssl:/etc/nginx/ssl:ro
    networks:
      - wp_network

networks:
  wp_network:
    driver: bridge
